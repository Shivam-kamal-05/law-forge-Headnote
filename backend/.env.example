# Law Lens — Headnote Forge
# Reference file — copy to .env and fill in your real values.
# Never commit .env to version control.

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ── Auth (demo gate) ──────────────────────────────────────────────────────────
# Single operator login. Defaults are baked into the code for the client demo;
# uncomment to override without touching source.
# AUTH_USERNAME=dharmani.dev
# AUTH_PASSWORD=dharmaniz@123
# AUTH_TOKEN_SECRET=change-me-in-production   # rotates issued bearer tokens

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # for a client demo, claude-sonnet-4-6 gives noticeably richer headnotes
ANTHROPIC_MAX_TOKENS=8192
ANTHROPIC_MAX_RETRIES=5
ANTHROPIC_TIMEOUT_SECONDS=120

# Rate limits — match your Anthropic usage tier.
# Tier 1 (default): 50 RPM / 50 000 TPM
ANTHROPIC_RPM=50
ANTHROPIC_TPM=50000

# ── Ingestion ─────────────────────────────────────────────────────────────────
INGESTION_OCR_ENABLED=true          # enable Tesseract fallback for scanned PDFs
INGESTION_OCR_DPI=300
INGESTION_MIN_TEXT_LENGTH=200       # minimum chars before OCR kicks in
INGESTION_MAX_FILE_BYTES=52428800   # 50 MiB per PDF
INGESTION_MAX_FILES_PER_REQUEST=10
INGESTION_CONCURRENCY=3             # simultaneous PDF → LLM pipelines
